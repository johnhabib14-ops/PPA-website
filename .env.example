# Public site URL (used for metadata / Open Graph). Use a full URL with protocol, e.g. https://www.yourdomain.com
# Domain-only values get https:// prepended; invalid values fall back to http://localhost:3000 so the app won’t 500.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: embedded intake (HIPAA-aligned vendor with BAA, e.g. Jotform HIPAA / Formstack) ---
# Set to "true" and provide the iframe URL from your vendor to show the embed above the built-in form.
NEXT_PUBLIC_USE_EMBEDDED_INTAKE=false
NEXT_PUBLIC_INTAKE_IFRAME_SRC=

# --- Option A: Webhook for contact submissions (Zapier, Make, Formstack endpoint, etc.) ---
# Server-side POST with JSON body: { source, submittedAt, name, email, phone, preferredService, message }
CONTACT_WEBHOOK_URL=

# --- Option B: Resend (review BAA / HIPAA suitability with your compliance advisor) ---
# Requires verified domain/sender in Resend. All three must be set to use this path.
RESEND_API_KEY=
CONTACT_EMAIL_TO=
CONTACT_EMAIL_FROM=
